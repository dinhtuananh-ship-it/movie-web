<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Admin Dashboard</title>

    <link
        rel="stylesheet"
        href="/css/style.css"
    >

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    >

</head>

<body>

<div class="admin-layout">

    <!-- SIDEBAR -->

    <div class="sidebar">

        <div>

            <h1 class="admin-logo">

                MOVIE ADMIN

            </h1>

            <a href="/admin">

                <i class="fa fa-chart-line"></i>

                Dashboard

            </a>

            <a href="/admin/add-movie">

                <i class="fa fa-plus"></i>

                Add Movie

            </a>

            <a href="/">

                <i class="fa fa-house"></i>

                Website

            </a>

        </div>

        <a
            href="/logout"
            class="logout-btn"
        >

            <i class="fa fa-right-from-bracket"></i>

            Logout

        </a>

    </div>

    <!-- CONTENT -->

    <div class="admin-content">

        <!-- TOPBAR -->

        <div class="admin-topbar">

            <div>

                <h2>

                    Dashboard

                </h2>

                <p>

                    Manage your streaming platform

                </p>

            </div>

            <div class="admin-user-box">

                <i class="fa fa-user"></i>

                <% if(typeof user !== 'undefined' && user){ %>

                    <span>

                        <%= user.name %>

                    </span>

                <% } else { %>

                    <span>

                        Admin

                    </span>

                <% } %>

            </div>

        </div>

        <!-- MOVIES -->

        <div class="admin-movie-grid">

            <% movies.forEach(movie => { %>

                <div class="admin-movie-card">

                    <!-- POSTER -->

                    <div class="admin-poster">

                        <img
                            src="<%= movie.thumbnail %>"
                        >

                        <% if(movie.trending_rank > 0){ %>

                            <div class="top-badge">

                                TOP
                                <%= movie.trending_rank %>

                            </div>

                        <% } %>

                    </div>

                    <!-- INFO -->

                    <div class="admin-movie-info">

                        <h3>

                            <%= movie.title %>

                        </h3>

                        <p>

                            <%= movie.category_name %>

                        </p>

                        <div class="admin-actions">

                            <a
                                href="/admin/edit/<%= movie.id %>"
                                class="edit-btn"
                            >

                                Edit

                            </a>

                            <a
                                href="/admin/delete/<%= movie.id %>"
                                class="delete-btn"
                            >

                                Delete

                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</div>

</body>

</html>